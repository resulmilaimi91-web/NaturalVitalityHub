{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "youtube-poster": {
      "description": "Posts videos from creato.ai to YouTube daily",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  },
  "mcp": {
    "youtube-api": {
      "type": "local",
      "command": ["python", "D:\\ANDROID\\opencode\\youtube_upload.py"],
      "enabled": true,
      "env": {
        "YOUTUBE_API_KEY": "${YOUTUBE_API_KEY}"
      }
    }
  },
  "skills": {
    "paths": [".opencode/skills"]
  }
}
